# Core app
NODE_ENV=development
ENV=development

# Convex (required)
CONVEX_DEPLOYMENT=dev:your-deployment-name
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# WorkOS auth (required if auth is enabled)
VITE_WORKOS_CLIENT_ID=client_xxx
WORKOS_CLIENT_ID=client_xxx
WORKOS_API_KEY=sk_test_xxx
WORKOS_WEBHOOK_SECRET=whsec_xxx

# AI provider keys
OPENAI_API_KEY=sk-proj-xxx
# XAI_API_KEY=xai-xxx

# Optional tracing/proxy
OPENAI_TRACES_PROXY_URL=https://your-proxy.example.com/run
PHOENIX_API_KEY=phx_xxx
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/v1/traces
OTEL_SERVICE_NAME=ai-storefront
OTEL_SERVICE_VERSION=1.0.0
OTEL_ENABLE_CONSOLE=true

# Optional email/marketing
RESEND_API_KEY=re_xxx
RESEND_AUDIENCE_LIST_ID=aud_xxx

# Optional python-agents settings
OPENAI_MODEL=gpt-4o-mini
# OPENAI_AGENTS_DISABLE_TRACING=1
